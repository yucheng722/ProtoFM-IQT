def conditional_sen_spe(y_true, y_score, target_spe=0.8, target_sen=0.8):

    fpr, tpr, thresholds = roc_curve(y_true, y_score)
    spe = 1 - fpr
    sen = tpr

    valid_idx = np.where(spe >= target_spe)[0]
    sen_at_target_spe = sen[valid_idx].max() if len(valid_idx) > 0 else 0.0

    valid_idx = np.where(sen >= target_sen)[0]
    spe_at_target_sen = spe[valid_idx].max() if len(valid_idx) > 0 else 0.0

    return sen_at_target_spe, spe_at_target_sen

class GradientReversalLayer(Function):
    @staticmethod
    def forward(ctx, x, alpha):
        ctx.alpha = alpha
        return x.view_as(x)

    @staticmethod
    def backward(ctx, grad_output):
        output = grad_output.neg() * ctx.alpha
        return output, None


def grad_reverse(x, alpha=1.0):
    return GradientReversalLayer.apply(x, alpha)


class ContrastiveLoss(nn.Module):
    def __init__(self, temperature=0.1, margin=1.0):
        super(ContrastiveLoss, self).__init__()
        self.temperature = temperature
        self.margin = margin
        self.cosine_similarity = nn.CosineSimilarity(dim=2)

    def forward(self, features, labels):
        batch_size = features.shape[0]

        features_norm = F.normalize(features, p=2, dim=1)
        similarity_matrix = torch.matmul(features_norm, features_norm.T) / self.temperature

        labels = labels.contiguous().view(-1, 1)
        mask = torch.eq(labels, labels.T).float()

        mask = mask - torch.eye(batch_size, device=mask.device)

        exp_sim = torch.exp(similarity_matrix)

        pos_pairs = mask * similarity_matrix
        pos_loss = - (mask * pos_pairs).sum() / (mask.sum() + 1e-8)

        neg_loss = torch.log(exp_sim.sum(dim=1) + 1e-8).mean()

        contrastive_loss = pos_loss + neg_loss

        return contrastive_loss


class PrototypeModule(nn.Module):
    def __init__(self, num_classes=2, feature_dim=512, momentum=0.9, learnable=True):
        super(PrototypeModule, self).__init__()
        self.num_classes = num_classes
        self.feature_dim = feature_dim
        self.momentum = momentum
        self.learnable = learnable

        if learnable:
            self.prototypes = nn.Parameter(torch.randn(num_classes, feature_dim))
        else:
            self.register_buffer('prototypes', torch.zeros(num_classes, feature_dim))

        self.register_buffer('class_count', torch.zeros(num_classes))

    def update_prototypes(self, features, labels):
        if not self.learnable:
            with torch.no_grad():
                for i in range(self.num_classes):
                    class_mask = (labels == i)
                    if class_mask.sum() > 0:
                        class_features = features[class_mask]
                        class_mean = class_features.mean(dim=0)

                        if self.class_count[i] == 0:
                            self.prototypes[i] = class_mean
                        else:
                            self.prototypes[i] = (self.momentum * self.prototypes[i] +
                                                  (1 - self.momentum) * class_mean)

                        self.class_count[i] += class_mask.sum()

    def forward(self, features):
        features_norm = F.normalize(features, p=2, dim=1)
        prototypes_norm = F.normalize(self.prototypes, p=2, dim=1)

        similarity = torch.matmul(features_norm, prototypes_norm.T)

        return similarity


def train_encoder(args,model, train_loader, val_loader, test_loader, device, epochs, save_dir,
                  lr=1e-4, contrastive_weight=0.5):
    model.train()
    optimizer = torch.optim.Adam(model.parameters(), lr=lr)
    criterion_cls = nn.CrossEntropyLoss()
    criterion_contrast = ContrastiveLoss()

    best_composite_score = 0.0
    best_epoch = 0
    history = {
        'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': [],
        'val_auc': [], 'val_sensitivity': [], 'val_specificity': [],
        'test_loss': [], 'test_acc': [],
        'test_auc': [], 'test_sensitivity': [], 'test_specificity': []
    }

    for epoch in range(epochs):
        model.train()
        running_loss = 0.0
        running_corrects = 0
        total_samples = 0

        for batch_idx, (images, labels) in enumerate(train_loader):
            images, labels = images.to(device), labels.to(device)
            if len(images.shape) == 4:  
                images = images.unsqueeze(1) 
            elif len(images.shape) == 5 and images.shape[1] != 1:
                if images.shape[1] == images.shape[2]:  
                    images = images.permute(1,0, 2, 3, 4)  

            optimizer.zero_grad()

            outputs, features = model(images)

            cls_loss = criterion_cls(outputs, labels)
            contrast_loss = criterion_contrast(features, labels)
            total_loss = cls_loss + args.contrast_weight * contrast_loss

            total_loss.backward()
            optimizer.step()

            running_loss += total_loss.item() * images.size(0)
            _, preds = torch.max(outputs, 1)
            running_corrects += torch.sum(preds == labels.data)
            total_samples += images.size(0)

            if batch_idx % 20 == 0:
                print(f'Epoch {epoch + 1}/{epochs}, Batch {batch_idx}, Loss: {total_loss.item():.4f}')

        epoch_loss = running_loss / total_samples
        epoch_acc = running_corrects.double() / total_samples

        val_metrics = evaluate_model(model, val_loader, device)

        composite_score = (
            0.3 * val_metrics['accuracy'] +      
            0.4 * val_metrics['sen@80spe'] +   
            0.2 * val_metrics['spe@80sen'] +   
            0.1 * val_metrics['auc']             
        )

        history['train_loss'].append(epoch_loss)
        history['train_acc'].append(epoch_acc.item())
        history['val_loss'].append(val_metrics['loss'])
        history['val_acc'].append(val_metrics['accuracy'])
        history['val_auc'].append(val_metrics['auc'])
        history['val_sensitivity'].append(val_metrics['sen@80spe'])
        history['val_specificity'].append(val_metrics['spe@80sen'])

        print(f'Epoch {epoch + 1}/{epochs}:')
        print(f'Train Loss: {epoch_loss:.4f}, Train Acc: {epoch_acc:.4f}')
        print(f'Val Loss: {val_metrics["loss"]:.4f}, Val Acc: {val_metrics["accuracy"]:.4f}')
        print(
            f'Val AUC: {val_metrics["auc"]:.4f}, Sensitivity: {val_metrics["sen@80spe"]:.4f}, Specificity: {val_metrics["spe@80sen"]:.4f}')

        torch.save({
            'epoch': epoch + 1,
            'model_state_dict': model.state_dict(),
            'optimizer_state_dict': optimizer.state_dict(),
            'metrics': val_metrics
        }, os.path.join(save_dir, f'encoder_epoch_{epoch + 1}.pth'))

        if composite_score > best_composite_score:
            best_composite_score = composite_score
            best_epoch = epoch + 1
            torch.save({
                'epoch': epoch + 1,
                'model_state_dict': model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'metrics': val_metrics,
                'composite_score': composite_score
            }, os.path.join(save_dir, 'best_encoder.pth'))
            print(f'New best model saved with composite score: {composite_score:.4f}')
            
        test_metrics = evaluate_model(model, test_loader, device)

        history['test_loss'].append(test_metrics['loss'])
        history['test_acc'].append(test_metrics['accuracy'])
        history['test_auc'].append(test_metrics['auc'])
        history['test_sensitivity'].append(test_metrics['sen@80spe'])
        history['test_specificity'].append(test_metrics['spe@80sen'])

        print(f'test Loss: {test_metrics["loss"]:.4f}, test Acc: {test_metrics["accuracy"]:.4f}')
        print(
            f'test AUC: {test_metrics["auc"]:.4f}, Sensitivity: {test_metrics["sen@80spe"]:.4f}, Specificity: {test_metrics["spe@80sen"]:.4f}')


    print(f'Training completed. Best epoch: {best_epoch} with composite score: {best_composite_score:.4f}')
    return history, os.path.join(save_dir, 'best_encoder.pth')  


def train_prototype(model, proto_module, train_loader, val_loader, test_loader, device, epochs,
                    save_dir, best_encoder_path, lr=1e-4):
    if lr is None:
        if proto_module.learnable:
            lr = 1e-2  
        else:
            lr = 1e-3  

    print(f"Using learning rate: {lr} for prototype training")
    if best_encoder_path and os.path.exists(best_encoder_path):
        print(f"Loading pre-trained encoder from: {best_encoder_path}")
        checkpoint = torch.load(
            best_encoder_path,
            map_location=device,
            weights_only=False
        )
        model.load_state_dict(checkpoint['model_state_dict'])
        print(
            f"Loaded encoder from epoch {checkpoint['epoch']} with composite score: {checkpoint.get('composite_score', 'N/A')}")
    else:
        print("Warning: No pre-trained encoder found. Training prototype from scratch.")

    for param in model.parameters():
        param.requires_grad = False

    for param in model.parameters():
        param.requires_grad = False

    if proto_module.learnable:
        optimizer = torch.optim.Adam(proto_module.parameters(), lr=lr)
    else:
        optimizer = None
    criterion_distance = CosinePrototypeLoss()
    best_acc = 0.0
    history = {
        'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': [],
        'val_auc': [], 'val_sensitivity': [], 'val_specificity': [],
        'test_loss': [], 'test_acc': [],
        'test_auc': [], 'test_sensitivity': [], 'test_specificity': []
    }

    for epoch in range(epochs):
        model.eval()
        proto_module.train()

        running_loss = 0.0
        running_corrects = 0
        total_samples = 0

        for batch_idx, (images, labels) in enumerate(train_loader):
            images, labels = images.to(device), labels.to(device)
            if len(images.shape) == 4:  
                images = images.unsqueeze(1) 
            elif len(images.shape) == 5 and images.shape[1] != 1:
                if images.shape[1] == images.shape[2]:  
                    images = images.permute(1, 0, 2, 3, 4)  

            if optimizer:
                optimizer.zero_grad()

            with torch.no_grad():
                _, features = model(images)

            if not proto_module.learnable:
                proto_module.update_prototypes(features, labels)

            similarity = proto_module(features)

            loss = 100*criterion_distance(features, proto_module.prototypes, labels)

            if optimizer:
                loss.backward()
                optimizer.step()

            running_loss += loss.item() * images.size(0)
            _, preds = torch.max(similarity, 1)
            running_corrects += torch.sum(preds == labels.data)
            total_samples += images.size(0)

            if batch_idx % 20 == 0:
                print(f'Proto Epoch {epoch + 1}/{epochs}, Batch {batch_idx}, Distance Loss: {loss.item():.4f}')

        epoch_loss = running_loss / total_samples
        epoch_acc = running_corrects.double() / total_samples

        val_metrics = evaluate_prototype_model(model, proto_module, val_loader, device)

        history['train_loss'].append(epoch_loss)
        history['train_acc'].append(epoch_acc.item())
        history['val_loss'].append(val_metrics['loss'])
        history['val_acc'].append(val_metrics['accuracy'])
        history['val_auc'].append(val_metrics['auc'])
        history['val_sensitivity'].append(val_metrics['sen@80spe'])
        history['val_specificity'].append(val_metrics['spe@80sen'])

        print(f'Proto Epoch {epoch + 1}/{epochs}:')
        print(f'Train Loss: {epoch_loss:.4f}, Train Acc: {epoch_acc:.4f}')
        print(f'Val Loss: {val_metrics["loss"]:.4f}, Val Acc: {val_metrics["accuracy"]:.4f}')
        print(
            f'Val AUC: {val_metrics["auc"]:.4f}, Sensitivity: {val_metrics["sen@80spe"]:.4f}, Specificity: {val_metrics["spe@80sen"]:.4f}')

        checkpoint = {
            'epoch': epoch + 1,
            'proto_module_state_dict': proto_module.state_dict(),
            'metrics': val_metrics,
            'prototypes': proto_module.prototypes.cpu().detach().numpy()
        }

        if optimizer:
            checkpoint['optimizer_state_dict'] = optimizer.state_dict()

        torch.save(checkpoint, os.path.join(save_dir, f'prototype_epoch_{epoch + 1}.pth'))

        np.save(os.path.join(save_dir, f'prototypes_epoch_{epoch + 1}.npy'),
                proto_module.prototypes.cpu().detach().numpy())
        composite_score = (
            0.3 * val_metrics['accuracy'] +      
            0.4 * val_metrics['sen@80spe'] +   
            0.2 * val_metrics['spe@80sen'] +   
            0.1 * val_metrics['auc']             
        )
        if composite_score > best_acc:
            best_acc = composite_score
            torch.save(proto_module.state_dict(), os.path.join(save_dir, 'best_prototype.pth'))
            np.save(os.path.join(save_dir, 'best_prototypes.npy'),
                    proto_module.prototypes.cpu().detach().numpy())
            
        test_metrics = evaluate_prototype_model(model, proto_module, test_loader, device)

        history['test_loss'].append(test_metrics['loss'])
        history['test_acc'].append(test_metrics['accuracy'])
        history['test_auc'].append(test_metrics['auc'])
        history['test_sensitivity'].append(test_metrics['sen@80spe'])
        history['test_specificity'].append(test_metrics['spe@80sen'])

        print(f'test Loss: {test_metrics["loss"]:.4f}, test Acc: {test_metrics["accuracy"]:.4f}')
        print(
            f'test AUC: {test_metrics["auc"]:.4f}, Sensitivity: {test_metrics["sen@80spe"]:.4f}, Specificity: {test_metrics["spe@80sen"]:.4f}')

    return history


def evaluate_model(model, data_loader, device):
    model.eval()
    criterion = nn.CrossEntropyLoss()

    running_loss = 0.0
    running_corrects = 0
    total_samples = 0

    all_labels = []
    all_probs = []
    all_preds = []

    with torch.no_grad():
        for images, labels in data_loader:
            images, labels = images.to(device), labels.to(device)
            if len(images.shape) == 4:  
                images = images.unsqueeze(1) 
            elif len(images.shape) == 5 and images.shape[1] != 1:
                if images.shape[1] == images.shape[2]: 
                    images = images.permute(1,0,2, 3, 4)  

            outputs, _ = model(images)
            loss = criterion(outputs, labels)

            running_loss += loss.item() * images.size(0)
            _, preds = torch.max(outputs, 1)
            running_corrects += torch.sum(preds == labels.data)
            total_samples += images.size(0)

            probs = F.softmax(outputs, dim=1)[:, 1]  
            all_labels.extend(labels.cpu().numpy())
            all_probs.extend(probs.cpu().numpy())
            all_preds.extend(preds.cpu().numpy())

    from sklearn.metrics import roc_auc_score, confusion_matrix

    accuracy = running_corrects.double() / total_samples
    avg_loss = running_loss / total_samples
    auc = roc_auc_score(all_labels, all_probs)

    sen80spe, spe80sen = conditional_sen_spe(
        np.array(all_labels),
        np.array(all_probs),
        target_spe=0.9,
        target_sen=0.9
    )

    return {
        'loss': avg_loss,
        'accuracy': accuracy.item(),
        'auc': auc,
        'sen@80spe': sen80spe,
        'spe@80sen': spe80sen
    }


