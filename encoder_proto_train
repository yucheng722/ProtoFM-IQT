def main():
    args = parse_args()
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    run_dir = os.path.join(args.output_dir, f"run_combined_{timestamp}")
    os.makedirs(run_dir, exist_ok=True)

    with open(os.path.join(run_dir, 'config.json'), 'w') as f:
        json.dump(vars(args), f, indent=4)

    print(f"Using device: {device}")
    print(f"Output directory: {run_dir}")

    (train_source_loader, train_target_loader,
     val_source_loader, val_target_loader) = (
        get_dataloader_single(
            "/path/to/data/dir",
            batch_size=args.batch_size
        )
    )

    source_dataset = train_source_loader.dataset
    target_dataset = train_target_loader.dataset

    source_len = len(source_dataset)
    target_len = len(target_dataset)
    source_val_size = int(0.2 * source_len)
    target_val_size = int(0.2 * target_len)

    torch.manual_seed(42)
    np.random.seed(42)

    source_indices = torch.randperm(source_len)
    target_indices = torch.randperm(target_len)

    source_val_indices = source_indices[:source_val_size]
    source_train_indices = source_indices[source_val_size:]

    target_val_indices = target_indices[:target_val_size]
    target_train_indices = target_indices[target_val_size:]

    from torch.utils.data import Subset

    source_train_dataset = Subset(source_dataset, source_train_indices)
    source_val_dataset = Subset(source_dataset, source_val_indices)

    target_train_dataset = Subset(target_dataset, target_train_indices)
    target_val_dataset = Subset(target_dataset, target_val_indices)

    train_dataset = ConcatDataset([
        source_train_dataset,
        target_train_dataset
    ])

    val_dataset = ConcatDataset([
        source_val_dataset,
        target_val_dataset
    ])

    class DomainBalancedBatchSampler:
        def __init__(self, source_dataset_len, target_dataset_len, batch_size, source_ratio=0.5):
            self.source_len = source_dataset_len
            self.target_len = target_dataset_len
            self.batch_size = batch_size
            self.source_ratio = source_ratio

            self.source_per_batch = int(batch_size * source_ratio)
            self.target_per_batch = batch_size - self.source_per_batch

            assert self.source_len >= self.source_per_batch
            assert self.target_len >= self.target_per_batch

            self.epoch_length = self.source_len // self.source_per_batch

            print(f"each batch: {self.source_per_batch} source, {self.target_per_batch} target")
            print(f"each epoch: {self.epoch_length} batches")
            print(f"source data used each epoch: {1}")
            print(f"target data used each epoch: {self.source_per_batch * self.epoch_length / self.target_len:.2f}")

        def __iter__(self):
            source_perm = torch.randperm(self.source_len)

            total_target_needed = self.target_per_batch * self.epoch_length
            target_indices = torch.randint(0, self.target_len, (total_target_needed,))

            for i in range(self.epoch_length):
                source_start = i * self.source_per_batch
                source_batch_idx = source_perm[source_start:source_start + self.source_per_batch].tolist()

                target_start = i * self.target_per_batch
                target_batch_idx = (target_indices[
                                    target_start:target_start + self.target_per_batch] + self.source_len).tolist()

                batch_indices = source_batch_idx + target_batch_idx

                if len(batch_indices) > 1:
                    batch_perm = torch.randperm(len(batch_indices))
                    batch_indices = [batch_indices[i] for i in batch_perm]

                yield batch_indices

        def __len__(self):
            return self.epoch_length


    class DomainBalancedBatchSamplerV2:
        def __init__(self, source_dataset_len, target_dataset_len, batch_size, source_ratio=0.5):
            self.source_len = source_dataset_len
            self.target_len = target_dataset_len
            self.batch_size = batch_size
            self.source_ratio = source_ratio

            self.source_per_batch = int(batch_size * source_ratio)
            self.target_per_batch = batch_size - self.source_per_batch

            assert self.source_len >= self.source_per_batch
            assert self.target_len >= self.target_per_batch

            self.epoch_length = self.source_len // self.source_per_batch

        def __iter__(self):
            source_perm = torch.randperm(self.source_len)

            for i in range(self.epoch_length):
                source_start = i * self.source_per_batch
                source_batch_idx = source_perm[source_start:source_start + self.source_per_batch].tolist()

                target_batch_idx = (
                            torch.randint(0, self.target_len, (self.target_per_batch,)) + self.source_len).tolist()

                batch_indices = source_batch_idx + target_batch_idx

                if len(batch_indices) > 1:
                    batch_perm = torch.randperm(len(batch_indices))
                    batch_indices = [batch_indices[i] for i in batch_perm]

                yield batch_indices

        def __len__(self):
            return self.epoch_length

    class DomainBalancedBatchSamplerV3:
        def __init__(self, source_dataset_len, target_dataset_len, batch_size,
                     source_ratio=0.5, iterations_per_epoch=None):
            self.source_len = source_dataset_len
            self.target_len = target_dataset_len
            self.batch_size = batch_size
            self.source_ratio = source_ratio

            self.source_per_batch = int(batch_size * source_ratio)
            self.target_per_batch = batch_size - self.source_per_batch

            assert self.source_len >= self.source_per_batch
            assert self.target_len >= self.target_per_batch

            if iterations_per_epoch is not None:
                self.epoch_length = iterations_per_epoch
            else:
                self.epoch_length = max(
                    self.source_len // self.source_per_batch,
                    self.target_len // self.target_per_batch
                )

            print(f"sampler config:")
            print(f"  source data size: {self.source_len}")
            print(f"  target data size: {self.target_len}")
            print(f"  each batch: {self.source_per_batch} source, {self.target_per_batch} target")
            print(f"  each epoch: {self.epoch_length} batches")

        def __iter__(self):
            source_perm = torch.randperm(self.source_len)
            target_perm = torch.randperm(self.target_len)

            source_pos = 0
            target_pos = 0

            for _ in range(self.epoch_length):
                if source_pos + self.source_per_batch > self.source_len:
                    source_perm = torch.randperm(self.source_len)
                    source_pos = 0

                source_batch_idx = source_perm[source_pos:source_pos + self.source_per_batch].tolist()
                source_pos += self.source_per_batch

                if target_pos + self.target_per_batch > self.target_len:
                    target_perm = torch.randperm(self.target_len)
                    target_pos = 0

                target_batch_idx = (
                            target_perm[target_pos:target_pos + self.target_per_batch] + self.source_len).tolist()
                target_pos += self.target_per_batch

                batch_indices = source_batch_idx + target_batch_idx

                if len(batch_indices) > 1:
                    batch_perm = torch.randperm(len(batch_indices))
                    batch_indices = [batch_indices[i] for i in batch_perm]

                yield batch_indices

        def __len__(self):
            return self.epoch_length

