    parser.add_argument('--train_0_dir', type=str,
                        default= '/path/to/data/train_0_dir',
                        help='Directory for class 0 training volumes')
    parser.add_argument('--train_1_dir', type=str,
                        default='/path/to/data/train_1_dir',
                        help='Directory for class 1 training volumes')
    parser.add_argument('--output_dir', type=str, default="./encoder",
                        help='Directory to save results and checkpoints')

    parser.add_argument('--batch_size', type=int, default=8, help='Batch size for training')
    parser.add_argument('--encoder_epochs', type=int, default=20, help='Number of encoder training epochs')
    parser.add_argument('--proto_epochs', type=int, default=30, help='Number of prototype training epochs')
